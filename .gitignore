# Samo naš kod: themes/kombo, themes/kombo-child, plugins/kombo-manager + README i ovaj fajl.
# Sve ostalo u wp-content/ (tuđi pluginovi, maintenance, uploads, keš, root fajlovi) ne ide na Git.

# Prvo: ignoriši sve direktno u wp-content/
/*
!/.gitignore
!/README.md
!/themes/
!/plugins/

# Teme: samo Kombo parent + child (+ themes/index.php ako postoji)
/themes/*
!/themes/kombo/
!/themes/kombo-child/
!/themes/index.php

# Pluginovi: samo naš
/plugins/*
!/plugins/kombo-manager/

# Logovi / env (bilo gde)
*.log
error_log
debug.log
.env
.env.*
